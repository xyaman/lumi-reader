# Per-environment secrets file. Copy to .kamal/secrets.dev or .kamal/secrets.prod
# (both gitignored) and adjust the source for your secret store.
#
# This example uses GitHub CLI for the registry token and the bitwarden adapter
# for the rest. Swap the adapter to whatever you use (1password, lastpass,
# aws_ssm_parameter_store, etc).

# ghcr.io login token from gh CLI.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Rails master key. Same key works for any RAILS_ENV unless you maintain
# per-env credential files.
RAILS_MASTER_KEY=$(cat config/master.key)

# Pull all other secrets from the secret store in one fetch.
SECRETS=$(kamal secrets fetch --adapter bitwarden --account <YOUR_EMAIL> --from <YOUR_SOURCE> \
  MAILGUN_DOMAIN \
  MAILGUN_SMTP_LOGIN \
  MAILGUN_SMTP_PASSWORD \
  PATREON_CAMPAIGN_ID \
  PATREON_CREATOR_ACCESS_TOKEN \
  PATREON_CLIENT_ID \
  PATREON_CLIENT_SECRET \
  PATREON_REDIRECT_URI)

MAILGUN_DOMAIN=$(kamal secrets extract MAILGUN_DOMAIN $SECRETS)
MAILGUN_SMTP_LOGIN=$(kamal secrets extract MAILGUN_SMTP_LOGIN $SECRETS)
MAILGUN_SMTP_PASSWORD=$(kamal secrets extract MAILGUN_SMTP_PASSWORD $SECRETS)

PATREON_CAMPAIGN_ID=$(kamal secrets extract PATREON_CAMPAIGN_ID $SECRETS)
PATREON_CREATOR_ACCESS_TOKEN=$(kamal secrets extract PATREON_CREATOR_ACCESS_TOKEN $SECRETS)
PATREON_CLIENT_ID=$(kamal secrets extract PATREON_CLIENT_ID $SECRETS)
PATREON_CLIENT_SECRET=$(kamal secrets extract PATREON_CLIENT_SECRET $SECRETS)
PATREON_REDIRECT_URI=$(kamal secrets extract PATREON_REDIRECT_URI $SECRETS)
